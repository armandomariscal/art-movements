# ===============================
# Application
# ===============================
PORT=3000
NODE_ENV=development

# ===============================
# Database
# ===============================
DB_NAME=art_movements
DB_PORT=27017

# Local connection (without auth)
MONGO_URL=mongodb://localhost:27017/art_movements

# Docker connection (with auth)
# Used when running via docker-compose
MONGO_USER=admin
MONGO_PASS=change_this_password
MONGO_URL_DOCKER=mongodb://admin:change_this_password@art-db:27017/art_movements?authSource=admin

# ===============================
# API
# ===============================
API_PORT=3000

# ===============================
# Frontend / Testing
# ===============================
BASE_URL=http://localhost:5173
API_URL=http://localhost:3000